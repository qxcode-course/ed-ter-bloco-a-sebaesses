            "content": "package main\n\nimport \"fmt\"\n\nfunc isValid(arr []byte, idx int, L int, char byte) bool {\n\tinicio := idx - L\n\tif inicio < 0 {\n\t\tinicio = 0\n\t}\n\tfor i := inicio; i < idx; i++ {\n\t\tif arr[i] == char {\n\t\t\treturn false\n\t\t}\n\t}\n\tfim := idx + L\n\tif fim >= len(arr) {\n\t\tfim = len(arr) - 1\n\t}\n\tfor i := idx + 1; i <= fim; i++ {\n\t\tif arr[i] == char {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\nfunc main() {\n\tvar seq string\n\tvar L int\n\n\tfor {\n\t\tn, _ := fmt.Scan(&seq, &L)\n\t\tif n != 2 {\n\t\t\tbreak\n\t\t}\n\t\tarr := []byte(seq)\n\t\tvar solve func(idx int) bool\n\t\tsolve = func(idx int) bool {\n\t\t\tif idx == len(arr) {\n\t\t\t\treturn true\n\t\t\t}\n\t\t\tif arr[idx] != '.' {\n\t\t\t\treturn solve(idx + 1)\n\t\t\t}\n\n\t\t\tfor d := 0; d <= L; d++ {\n\t\t\t\tif isValid(arr, idx, L, '0'+byte(d)) {\n\t\t\t\t\tarr[idx] = '0' + byte(d)\n\t\t\t\t\tif solve(idx + 1) {\n\t\t\t\t\t\treturn true\n\t\t\t\t\t}\n\t\t\t\t\tarr[idx] = '.'\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn false\n\t\t}\n\t\tsolve(0)\n\t\tfmt.Println(string(arr))\n\t}\n}\n",
